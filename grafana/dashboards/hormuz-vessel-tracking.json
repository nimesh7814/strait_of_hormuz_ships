        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse"
          },
          "editorType": "sql",
          "queryType": "sql",
          "rawSql": "SELECT\n  ship_id,\n  ship_name,\n  lat,\n  lon,\n  speed,\n  nav_label,\n  multiIf(\n    nav_label = 'Moored', 0,\n    nav_label = 'Underway (engine)', 1,\n    nav_label = 'At anchor', 2,\n    nav_label = 'Restricted manoeuvrability', 3,\n    nav_label = 'Underway (sailing)', 4,\n    nav_label = 'Not under command', 5,\n    6\n  ) AS status_idx\nFROM (\n  SELECT\n    ship_id,\n    argMax(ship_name, ts) AS ship_name,\n    argMax(latitude, ts) AS lat,\n    argMax(longitude, ts) AS lon,\n    argMax(speed, ts) AS speed,\n    argMax(nav_label, ts) AS nav_label\n  FROM vessels_tracking.ais_data\n  WHERE $__timeFilter(ts)\n  GROUP BY ship_id\n)\nORDER BY ship_id ASC",
          "refId": "A"
        }
      ],
      "title": "Strait of Hormuz Ship Movement",
      "type": "geomap"
    },
